# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===========================================
# OpenAI
# ===========================================
OPENAI_API_KEY=sk-...

# ===========================================
# Twilio (WhatsApp)
# ===========================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: job alerts outside the 24h WhatsApp session (fixes Twilio error 63016).
# Create & approve a Content template, then set Content SID + variables {{1}}–{{6}}.
# Guide: https://www.twilio.com/docs/whatsapp/tutorial/send-whatsapp-notification-messages-templates
# TWILIO_WHATSAPP_JOB_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Messaging Service SID (MG...) — often used with Content templates per Twilio docs.
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Adzuna (optional - free tier)
# Sign up at https://developer.adzuna.com/
# ===========================================
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ===========================================
# Telegram (optional — job alerts in addition to WhatsApp)
# Create a bot with @BotFather, then set webhook to https://YOUR_DOMAIN/api/webhook/telegram
# Optional: setWebhook secret_token → must match TELEGRAM_WEBHOOK_SECRET (header X-Telegram-Bot-Api-Secret-Token)
# ===========================================
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_BOT_USERNAME=YourJobBot
# TELEGRAM_WEBHOOK_SECRET=long-random-string

# ===========================================
# Scrape API Protection
# Set a random secret to protect the /api/scrape endpoint
# ===========================================
SCRAPE_API_KEY=your-random-secret-key-here

# ===========================================
# WhatsApp Group Listener (Baileys)
# Run: npm run whatsapp:groups to discover JIDs
# ===========================================
WHATSAPP_GROUP_IDS=

# ===========================================
# AWS Lambda (only needed in Lambda environment)
# ===========================================
# APP_URL=https://your-deployed-app.com
