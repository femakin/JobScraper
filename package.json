{
  "name": "jobscraper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:health": "curl -s http://localhost:3000/api/health | node -e \"process.stdin.on('data',d=>{const j=JSON.parse(d);console.log(JSON.stringify(j,null,2))})\"",
    "test:scraper": "curl -s 'http://localhost:3000/api/test-scraper?source=remotive' | node -e \"process.stdin.on('data',d=>{const j=JSON.parse(d);console.log(JSON.stringify(j,null,2))})\"",
    "test:scrape-run": "curl -s -X POST http://localhost:3000/api/scrape -H 'Authorization: Bearer dev-secret-key' | node -e \"process.stdin.on('data',d=>{const j=JSON.parse(d);console.log(JSON.stringify(j,null,2))})\"",
    "lambda:build": "npx esbuild lambda/scraper-handler.ts --bundle --platform=node --target=node20 --outfile=lambda/dist/index.js",
    "lambda:zip": "cd lambda/dist && zip -r function.zip index.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/supabase-js": "^2.102.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
